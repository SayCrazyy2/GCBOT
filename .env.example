# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token from @BotFather.
TELEGRAM_TOKEN=your-telegram-bot-token-here

# ── Security ──────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to use the bot.
# Run /start and check your user ID with @userinfobot.
# Leave empty to allow ALL users (not recommended for bots on a shared machine).
ALLOWED_USERS=123456789,987654321

# ── Workspace ─────────────────────────────────────────────────────────────────

# Dedicated directory where the AI can read, write, and delete files.
# All /ls, /cat, /write, /rm, /mkdir, /upload, /download commands are confined
# to this directory.  It is created automatically if it does not exist.
WORKSPACE_DIR=/home/youruser/gcbot-workspace

# ── Execution ─────────────────────────────────────────────────────────────────

# Maximum number of characters returned to Telegram for a command's output.
# Telegram messages are capped at 4096 chars; leave headroom for the suggestion.
MAX_OUTPUT_LENGTH=3500

# Maximum file size in bytes that /download will send via Telegram (default 20 MB).
MAX_DOWNLOAD_SIZE=20971520

# Seconds before a running command is killed (default: 120).
COMMAND_TIMEOUT=120

# Seconds to wait for gh copilot to return a suggestion (default: 60).
COPILOT_TIMEOUT=60
